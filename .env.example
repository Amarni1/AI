# Frontend API base URL
# Local development example:
# VITE_API_URL=http://localhost:4000
#
# External deployed backend example:
# VITE_API_URL=https://your-backend.onrender.com
#
# If the frontend is deployed on Netlify and using same-site Netlify Functions,
# leave VITE_API_URL unset so requests use the current site's /api/* routes.
VITE_API_URL=

# Optional live exchange route for swap execution.
# If this is unset, confirmed swaps still call MiniMask and use the connected
# wallet route as the default destination for the demo swap flow.
VITE_EXCHANGE_ADDRESS=
