# Frontend-only MiniMask swap runtime
# These are optional client-side settings used by the Vite app.

# Tiny signal amount used when a real token id is unavailable and the app
# needs to write swap metadata on-chain through a minimal Minima transaction.
VITE_SWAP_SIGNAL_AMOUNT=0.0001

# Real Minima token id for USDT.
VITE_SWAP_TOKEN_ID_USDT=0x7E6E60E033C7F74400B02F270074D0DA99FB863C33F8EA75078219258DCFC6CE
